@startuml VOPC_BookGameSeat_Complete

' ============================================================
' VOPC - BookGameSeat Use Case (VERSIONE COMPLETA)
' Con DAO, Bean, e architettura completa conforme al codice
' ============================================================

title VOPC - BookGameSeat Use Case (Complete with DAO & Bean)

' ============================================================
' CONFIGURAZIONE STILE
' ============================================================

skinparam backgroundColor white
skinparam shadowing false
skinparam classAttributeIconSize 0

skinparam class {
    BackgroundColor<<boundary>> LightBlue
    BackgroundColor<<control>> LightGreen
    BackgroundColor<<entity>> LightYellow
    BackgroundColor<<bean>> Wheat
    BackgroundColor<<interface>> White
    BorderColor Black
    ArrowColor Black
}

' ============================================================
' BOUNDARY (Interfaccia Utente)
' ============================================================

package "Boundary Layer" {
    class FanBookGameSeat <<boundary>> {
        + execute(): void
        + selectGame(): NbaGameBean
        + requestVenueFilters(): VenueFilters
        + selectVenue(): VenueBean
        + confirmBooking(): boolean
        + displayGamesList(games: List<NbaGameBean>): void
        + displayVenuesList(venues: List<VenueBean>): void
        + displayVenueDetails(venue: VenueBean): void
        + displayConfirmationCode(code: String): void
        + displayError(message: String): void
        + offerWaitlist(venue: VenueBean): void
    }

    class VenueManagerBookGameSeat <<boundary>> {
        + execute(): void
        + displayNewBookingNotification(notification: NotificationBean): void
        + displayNotificationBadge(count: int): void
    }

    class FanManageSeats <<boundary>> {
        + execute(): void
        + selectBooking(): BookingBean
        + requestFilterCriteria(): FilterCriteria
        + requestCancellation(): boolean
        + displayBookingList(bookings: List<BookingBean>): void
        + displayBookingDetails(booking: BookingBean): void
        + displayNotifications(notifications: List<NotificationBean>): void
        + displaySuccess(message: String): void
        + displayError(message: String): void
    }

    class VenueManagerManageVenues <<boundary>> {
        + execute(): void
        + selectVenue(): VenueBean
        + selectOperation(): String
        + selectBookingRequest(): BookingBean
        + requestDecision(): boolean
        + requestFilterCriteria(): FilterCriteria
        + requestTeamToAdd(): NbaTeam
        + requestTeamToRemove(): NbaTeam
        + displayVenueList(venues: List<VenueBean>): void
        + displayVenueDetails(venue: VenueBean): void
        + displayVenueOperations(): void
        + displayBookingList(bookings: List<BookingBean>): void
        + displayBookingDetails(booking: BookingBean): void
        + displayNotifications(notifications: List<NotificationBean>): void
        + displaySuccess(message: String): void
        + displayError(message: String): void
    }

    class BookGameSeatNBASchedule <<boundary>> {
        + fetchUpcomingGames(): List<NbaGameBean>
        + parseGameResponse(json: String): List<NbaGameBean>
        + handleApiError(exception: Exception): void
    }
}

' ============================================================
' CONTROLLER (Logica Applicativa - Singleton)
' ============================================================

package "Controller Layer" {
    class BookGameSeatController <<control>> {
        - {static} instance: BookGameSeatController
        - nbaScheduleService: BookGameSeatNBASchedule
        __
        + {static} getInstance(): BookGameSeatController
        __
        + getAvailableGames(): List<NbaGameBean>
        + getAvailableVenues(game: NbaGameBean, filters: VenueFilters): List<VenueBean>
        + checkVenueAvailability(venueId: int, date: LocalDate): boolean
        + submitBookingRequest(fanUsername: String, venueId: int, gameBean: NbaGameBean): String
        + cancelBookingRequest(bookingId: int): void
        + offerWaitlist(venueId: int): void
        - applyFilters(venues: List<Venue>, filters: VenueFilters): List<Venue>
        - convertVenueToBean(venue: Venue): VenueBean
        - convertBookingToBean(booking: Booking): BookingBean
    }

    class ManageVenuesController <<control>> {
        - {static} instance: ManageVenuesController
        __
        + {static} getInstance(): ManageVenuesController
        __
        + getManagerVenues(managerUsername: String): List<VenueBean>
        + getVenueDetails(venueId: int): VenueBean
        + addTeamToVenue(venueId: int, team: NbaTeam): void
        + removeTeamFromVenue(venueId: int, team: NbaTeam): void
        + getBookingsForVenue(venueId: int, filters: FilterCriteria): List<BookingBean>
        + getPendingBookings(managerUsername: String): List<BookingBean>
        + acceptBookingRequest(managerUsername: String, bookingId: int): void
        + rejectBookingRequest(managerUsername: String, bookingId: int): void
        + getManagerNotifications(managerUsername: String): List<NotificationBean>
        + markNotificationAsRead(notificationId: Long): void
        - applyBookingFilters(bookings: List<Booking>, filters: FilterCriteria): List<Booking>
        - validateVenueOwnership(manager: VenueManager, venue: Venue): boolean
        - convertVenueToBean(venue: Venue): VenueBean
        - convertBookingToBean(booking: Booking): BookingBean
        - convertNotificationToBean(notification: Notification): NotificationBean
    }

    class ManageSeatsController <<control>> {
        - {static} instance: ManageSeatsController
        __
        + {static} getInstance(): ManageSeatsController
        __
        + getFanBookings(fanUsername: String, filters: FilterCriteria): List<BookingBean>
        + getBookingDetails(bookingId: int): BookingBean
        + cancelBooking(fanUsername: String, bookingId: int): void
        + getFanNotifications(fanUsername: String): List<NotificationBean>
        + markNotificationAsRead(notificationId: Long): void
        - applyBookingFilters(bookings: List<Booking>, filters: FilterCriteria): List<Booking>
        - validateBookingOwnership(fan: Fan, booking: Booking): boolean
        - convertBookingToBean(booking: Booking): BookingBean
        - convertNotificationToBean(notification: Notification): NotificationBean
    }

    class NotificationController <<control>> {
        - {static} instance: NotificationController
        __
        + {static} getInstance(): NotificationController
        __
        + notifyVenueManager(booking: Booking): void
        + notifyFan(booking: Booking, status: BookingStatus): void
        - createNotificationForVenueManager(booking: Booking): NotificationBean
        - createNotificationForFan(booking: Booking, status: BookingStatus): NotificationBean
    }
}

' ============================================================
' DAO FACADE & FACTORY
' ============================================================

package "DAO Factory & Facade" {
    class DaoFactoryFacade <<control>> {
        - {static} instance: DaoFactoryFacade
        - persistenceType: PersistenceType
        __
        + {static} getInstance(): DaoFactoryFacade
        __
        + getFanDao(): FanDao
        + getVenueDao(): VenueDao
        + getVenueManagerDao(): VenueManagerDao
        + getBookingDao(): BookingDao
        + getNotificationDao(): NotificationDao
        + setPersistenceType(type: PersistenceType): void
    }
}

' ============================================================
' DAO INTERFACES
' ============================================================

package "DAO Interfaces" {
    interface FanDao <<interface>> {
        + retrieveFan(username: String): Fan
        + saveFan(fanBean: FanBean): void
        + updateFan(fanBean: FanBean): void
    }

    interface VenueDao <<interface>> {
        + retrieveVenue(id: int): Venue
        + saveVenue(venueBean: VenueBean): void
        + updateVenue(venueBean: VenueBean): void
        + getVenuesByFilters(filters: VenueFilters): List<Venue>
        + getVenuesByManager(managerUsername: String): List<Venue>
    }

    interface VenueManagerDao <<interface>> {
        + retrieveVenueManager(username: String): VenueManager
        + saveVenueManager(vmBean: VenueManagerBean): void
        + updateVenueManager(vmBean: VenueManagerBean): void
    }

    interface BookingDao <<interface>> {
        + saveBooking(bookingBean: BookingBean): Booking
        + retrieveBooking(id: int): Booking
        + updateBookingStatus(id: int, status: BookingStatus): void
        + getBookingsByFan(fanUsername: String): List<Booking>
        + getBookingsByVenue(venueId: int): List<Booking>
        + getBookingsByManager(managerUsername: String): List<Booking>
        + deleteBooking(id: int): void
    }

    interface NotificationDao <<interface>> {
        + saveNotification(notificationBean: NotificationBean): void
        + getNotificationsForUser(userId: Long, userType: UserType): List<Notification>
        + markAsRead(notificationId: Long): void
        + deleteNotification(id: Long): void
    }
}

' ============================================================
' BEAN (Data Transfer Objects)
' ============================================================

package "Bean Layer (DTO)" {
    class VenueBean <<bean>> {
        + id: int
        + name: String
        + type: VenueType
        + address: String
        + city: String
        + maxCapacity: int
        + venueManagerUsername: String
        __
        + Builder
    }

    class BookingBean <<bean>> {
        + id: int
        + gameDate: LocalDate
        + gameTime: LocalTime
        + homeTeam: TeamNBA
        + awayTeam: TeamNBA
        + venueId: int
        + fanUsername: String
        + status: BookingStatus
        + notified: boolean
        __
        + Builder
    }

    class NotificationBean <<bean>> {
        + id: Long
        + userId: Long
        + userType: UserType
        + type: NotificationType
        + message: String
        + relatedBookingId: Long
        + isRead: boolean
        + createdAt: LocalDateTime
        __
        + Builder
    }

    class NbaGameBean <<bean>> {
        + homeTeam: String
        + awayTeam: String
        + gameDate: LocalDate
        + gameTime: LocalTime
        + venue: String
        + city: String
        __
        + Builder
    }
}

' ============================================================
' ENTITY (Dominio)
' ============================================================

package "Entity Layer (Model)" {
    class Fan <<entity>> {
        - username: String
        - fullName: String
        - favTeam: TeamNBA
        - birthday: LocalDate
        - bookingList: List<Booking>
        __
        + addBooking(booking: Booking): void
        + cancelBooking(bookingId: int): boolean
        + getBookingList(): List<Booking>
        + getUpcomingBookings(): List<Booking>
    }

    class VenueManager <<entity>> {
        - username: String
        - fullName: String
        - companyName: String
        - phoneNumber: String
        - managedVenues: List<Venue>
        __
        + confirmBooking(booking: Booking, fan: Fan, venue: Venue): void
        + rejectBooking(booking: Booking, venue: Venue): void
        + getAllPendingBookings(): List<Booking>
        + getManagedVenues(): List<Venue>
        + addVenue(venue: Venue): void
    }

    class Venue <<entity>> {
        - id: int
        - name: String
        - type: VenueType
        - address: String
        - city: String
        - maxCapacity: int
        - associatedTeams: Set<TeamNBA>
        - venueManager: VenueManager
        - bookingsByDate: Map<LocalDate, List<Booking>>
        __
        + hasAvailableCapacity(date: LocalDate): boolean
        + getRemainingCapacity(date: LocalDate): int
        + addBooking(booking: Booking): void
        + addTeam(team: NbaTeam): void
        + removeTeam(team: NbaTeam): boolean
        + isTeamAssociated(team: NbaTeam): boolean
        + getBookingsByDate(date: LocalDate): List<Booking>
    }

    class Booking <<entity>> {
        - id: int
        - gameDate: LocalDate
        - gameTime: LocalTime
        - homeTeam: TeamNBA
        - awayTeam: TeamNBA
        - venue: Venue
        - fan: Fan
        - status: BookingStatus
        - notified: boolean
        __
        + confirm(): void
        + reject(): void
        + cancel(): void
        + markAsNotified(): void
        + getMatchup(): String
        + isFavoriteTeamPlaying(team: TeamNBA): boolean
    }

    class Notification <<entity>> {
        - id: Long
        - userId: Long
        - userType: UserType
        - type: NotificationType
        - message: String
        - relatedBookingId: Long
        - isRead: boolean
        - createdAt: LocalDateTime
        __
        + markAsRead(): Notification
        + isUnread(): boolean
    }
}

' ============================================================
' RELAZIONI BOUNDARY -> CONTROLLER
' ============================================================

FanBookGameSeat --> BookGameSeatController : usa
VenueManagerBookGameSeat --> ManageVenuesController : usa
FanManageSeats --> ManageSeatsController : usa
VenueManagerManageVenues --> ManageVenuesController : usa

BookGameSeatController --> BookGameSeatNBASchedule : usa

' ============================================================
' RELAZIONI TRA CONTROLLER
' ============================================================

BookGameSeatController --> NotificationController : usa
ManageVenuesController --> NotificationController : usa

' ============================================================
' RELAZIONI CONTROLLER -> FACADE -> DAO
' ============================================================

BookGameSeatController --> DaoFactoryFacade : usa
ManageVenuesController --> DaoFactoryFacade : usa
ManageSeatsController --> DaoFactoryFacade : usa
NotificationController --> DaoFactoryFacade : usa

DaoFactoryFacade --> FanDao : crea
DaoFactoryFacade --> VenueDao : crea
DaoFactoryFacade --> VenueManagerDao : crea
DaoFactoryFacade --> BookingDao : crea
DaoFactoryFacade --> NotificationDao : crea

' ============================================================
' RELAZIONI DAO -> ENTITY (accesso dati)
' ============================================================

FanDao --> Fan : usa
VenueDao --> Venue : usa
VenueManagerDao --> VenueManager : usa
BookingDao --> Booking : usa
NotificationDao --> Notification : usa

' ============================================================
' RELAZIONI CONTROLLER -> BEAN (creazione e conversione)
' ============================================================

BookGameSeatController ..> VenueBean : <<create>>
BookGameSeatController ..> BookingBean : <<create>>
BookGameSeatController ..> NbaGameBean : <<create>>

ManageVenuesController ..> VenueBean : <<create>>
ManageVenuesController ..> BookingBean : <<create>>
ManageVenuesController ..> NotificationBean : <<create>>

ManageSeatsController ..> BookingBean : <<create>>
ManageSeatsController ..> NotificationBean : <<create>>

NotificationController ..> NotificationBean : <<create>>

' ============================================================
' RELAZIONI BOUNDARY -> BEAN (visualizzazione)
' ============================================================

FanBookGameSeat ..> VenueBean : visualizza
FanBookGameSeat ..> NbaGameBean : visualizza
FanManageSeats ..> BookingBean : visualizza
FanManageSeats ..> NotificationBean : visualizza
VenueManagerManageVenues ..> VenueBean : visualizza
VenueManagerManageVenues ..> BookingBean : visualizza
VenueManagerManageVenues ..> NotificationBean : visualizza
VenueManagerBookGameSeat ..> NotificationBean : visualizza

' ============================================================
' RELAZIONI TRA ENTITY
' ============================================================

' COMPOSIZIONE: Fan è il "tutto", Booking è la "parte"
Fan "1" *-- "0..*" Booking : ha

' AGGREGAZIONE: VenueManager gestisce Venue
VenueManager "1" o-- "1..*" Venue : gestisce

' AGGREGAZIONE: Venue ospita Booking
Venue "1" o-- "0..*" Booking : ospita

' ASSOCIAZIONE SEMPLICE: navigabilità inversa
Booking "*" --> "1" Fan : prenotata da
Booking "*" --> "1" Venue : presso

' ============================================================
' NOTE
' ============================================================

note right of BookGameSeatController
  <b>Flusso BookGameSeat</b>

  1. Boundary chiama getAvailableGames()
  2. Controller usa NbaScheduleService
     (restituisce List<NbaGameBean>)
  3. Fan seleziona game
  4. Boundary chiama getAvailableVenues()
  5. Controller usa VenueDao (via Facade)
  6. Applica filtri, converte Venue → VenueBean
  7. Fan seleziona venue
  8. Boundary chiama submitBookingRequest()
  9. Controller:
     - Usa FanDao per recuperare Fan
     - Usa VenueDao per recuperare Venue
     - Crea Booking (Model)
     - Chiama Fan.addBooking()
     - Chiama Venue.addBooking()
     - Usa BookingDao per salvare
     - Converte Booking → BookingBean
     - Chiama NotificationController
  10. Restituisce confirmationCode
end note

note right of NotificationController
  <b>Gestione Notifiche</b>

  1. Riceve Booking (Model)
  2. Crea NotificationBean
  3. Usa NotificationDao (via Facade)
  4. Salva notifica in persistenza

  <b>Disaccoppiamento</b>
  Nessuna dipendenza circolare
  tra controller principali
end note

note bottom of DaoFactoryFacade
  <b>Pattern Facade</b>

  Fornisce accesso unificato
  a tutti i DAO.

  Gestisce la creazione tramite
  le Factory concrete.

  Configura automaticamente
  gli Observer per sync
  MySQL ↔ CSV
end note

note as N1
  <b>ARCHITETTURA COMPLETA</b>

  Flusso dati:
  1. Boundary lavora SOLO con Bean
  2. Controller riceve Bean (input)
  3. Controller usa Facade → DAO
  4. DAO accede Entity (Model)
  5. Controller converte Model → Bean
  6. Controller restituisce Bean (output)
  7. Boundary visualizza Bean

  <b>Separazione responsabilità:</b>
  - Boundary: UI, nessuna logica
  - Controller: logica applicativa
  - DAO: persistenza
  - Entity: logica di dominio
  - Bean: trasferimento dati
end note

note bottom of Fan
  <b>COMPOSIZIONE</b>
  Fan *-- Booking

  Lifecycle dipendente:
  eliminando Fan si eliminano
  tutte le sue Booking

  Simbolo: ◆ (rombo pieno)
end note

note bottom of VenueManager
  <b>AGGREGAZIONE</b>
  VenueManager o-- Venue

  Lifecycle indipendente:
  Venue può essere trasferita
  a un altro manager

  Simbolo: ◇ (rombo vuoto)
end note

@enduml
